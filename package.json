    "cache:species-images": "node --experimental-strip-types scripts/cache-species-images.ts",
    "find:ebird-hotspots": "node --experimental-strip-types scripts/find-ebird-hotspots.ts",
    "fetch:ebird": "node --experimental-strip-types scripts/fetch-ebird-species.ts",
